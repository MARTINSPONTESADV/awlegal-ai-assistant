# ───────────────────────────────────────────────────────────────
# AW ECO — template de .env
# Cada deploy (advogado/escritório) configura as variáveis abaixo
# no Vercel/Netlify. O código-fonte é o mesmo para todos.
# ───────────────────────────────────────────────────────────────

# ─── Supabase (obrigatório) ────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase Marketing (opcional, usado na aba Marketing/Gastos) ──
VITE_MARKETING_SUPABASE_URL=https://yyyyyyyyyyyyyyyyyyyy.supabase.co
VITE_MARKETING_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── n8n (opcional, usado pelo /atendimento) ───────────────────
# Ex: https://n8n.seudominio.com.br
VITE_N8N_BASE_URL=https://n8n.seudominio.com.br

# ─── Branding do tenant ────────────────────────────────────────
# Nome exibido no header, sidebar, títulos de aba
VITE_APP_NAME=AW ECO
# Tagline abaixo do nome no sidebar
VITE_APP_TAGLINE=Ecossistema
# Nome do escritório (copyright, docs gerados)
VITE_OFFICE_NAME=AW LEGALTECH
# URL do logo customizado (SVG/PNG). Omita pra usar o ícone padrão.
# VITE_LOGO_URL=https://seusite.com/logo.svg
# Ano de referência pro copyright
VITE_COPYRIGHT_YEAR=2026

# ─── Features habilitadas neste tenant ─────────────────────────
# CSV dos sub-sistemas que aparecem no HomeHub + sidebar.
# Valores válidos: system, crm, pre, fin
# Default (se omitido): todos os 4 habilitados.
#
# Ex só jurídico + financeiro:
#   VITE_FEATURES=system,fin
#
# Ex completo:
VITE_FEATURES=system,crm,pre,fin
